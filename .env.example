# Backend API (copy to .env in this folder — do not commit .env)
# Loaded automatically when you run npm run dev / npm start (see src/server.ts).

# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# First-wave EVM networks
# The UI shows friendly network names, while the API still uses chainId internally.
# Comma-separated fallbacks are supported for every chain.
RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_URLS_1=https://primary,https://fallback
RPC_URL=https://...   (alias used when chainId is 1 if RPC_URL_1 unset)
RPC_URL_56=             # BNB Smart Chain (chainId 56)
RPC_URL_137=            # Polygon (chainId 137)
RPC_URL_42161=          # Arbitrum One (chainId 42161)
RPC_URL_10=             # Optimism (chainId 10)
RPC_URL_8453=           # Base (chainId 8453)
# Avalanche C-Chain (43114) — set for live analysis + router quotes (Trader Joe V1–compatible router in registry)
RPC_URL_43114=https://avax-mainnet.g.alchemy.com/v2/YOUR_KEY   # Avalanche (chainId 43114)
RPC_URL_59144=          # Linea (chainId 59144)
RPC_URL_324=            # zkSync Era (chainId 324)
RPC_URL_11155111=       # Ethereum Sepolia Testnet (chainId 11155111)

# Redis (optional — in-memory cache if unavailable)
REDIS_URL=redis://127.0.0.1:6379
CACHE_TTL_SECONDS=300

# CORS — list full origins (scheme + host + port). Browsers send e.g. https://your-app.vercel.app
# Production: include your Vercel URL(s) with https:// (hostnames alone will not match).
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://coinstore-web3-risk-defense-mvp-fro.vercel.app

# Risk / AI thresholds
AI_THRESHOLD_LOW=60
AI_THRESHOLD_HIGH=84
RULESET_VERSION=2.0.0
REAL_CHAIN_STRICT=true
STRICT_MODE=true

# Rate limits
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_API_KEY_PER_MINUTE=600

# Optional API auth (requires x-api-key header on /api/analyze and /api/demo)
# API_KEY=

# Intel lists (comma-separated addresses)
INTEL_DENY_TOKENS=
INTEL_DENY_WALLETS=
INTEL_ALLOW_TOKENS=

# Optional external wallet intel (GET {base}/wallet/:address)
WALLET_INTEL_URL=
WALLET_INTEL_TIMEOUT_MS=2500

# Feature flags
FEATURE_DEEP_SIMULATION=false
